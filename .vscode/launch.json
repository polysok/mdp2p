{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Demo",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/demo.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Tracker",
            "type": "debugpy",
            "request": "launch",
            "module": "tracker",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run MDP2P Client",
            "type": "debugpy",
            "request": "launch",
            "module": "mdp2p_client",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
